# For `wrangler dev` only. Copy to .dev.vars and fill in. Do not commit .dev.vars.
# Production uses `wrangler secret put` instead.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe test mode (Dashboard → Developers → API keys / Webhooks)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Worker HTTPS base (Stripe Connect account link return/refresh)
# WORKER_PUBLIC_URL=https://wild-mountain-072a.n-vandullemen.workers.dev

# Optional deep links (defaults match app.json scheme lumen-fashion)
# Optional deep link for "Terug naar app" on Worker checkout pages (app sends HTTPS success/cancel URLs by default)
# CHECKOUT_SUCCESS_URL=lumen-fashion://checkout/success?session_id={CHECKOUT_SESSION_ID}
# CHECKOUT_CANCEL_URL=lumen-fashion://checkout/cancel

# KVK Handelsregister Basisprofiel (seller onboarding)
# Productie-key via https://developers.kvk.nl (betaald abonnement)
KVK_API_BASE=https://api.kvk.nl/api/v1
KVK_API_KEY=your-production-kvk-api-key
# Test (gratis fictieve data): KVK_API_BASE=https://api.kvk.nl/test/api/v1
#                           KVK_API_KEY=l7xx1f2691f2520d487b902f4e0b57a0b197
