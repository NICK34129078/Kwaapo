{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "App: start in Cursor (web)",
      "type": "npm",
      "script": "start:cursor",
      "isBackground": true,
      "problemMatcher": {
        "owner": "expo",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "(Starting|env:)",
          "endsPattern": "(Web is waiting on|webpack compiled|Logs for your project|http://localhost)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
