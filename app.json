{
  "expo": {
    "name": "Lumen",
    "slug": "lumen-fashion",
    "scheme": "lumen-fashion",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0B0B0B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lumen.fashion",
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "whatsapp",
          "instagram",
          "snapchat",
          "discord"
        ]
      }
    },
    "android": {
      "package": "com.lumen.fashion"
    },
    "plugins": [
      "expo-web-browser"
    ]
  }
}
