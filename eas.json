{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "store",
      "environment": "preview",
      "ios": {
        "simulator": false
      },
      "channel": "preview"
    },
    "production": {
      "distribution": "store",
      "environment": "production",
      "autoIncrement": true,
      "ios": {
        "simulator": false
      },
      "channel": "production"
    }
  },
  "submit": {
    "preview": {
      "ios": {}
    },
    "production": {
      "ios": {}
    }
  }
}
