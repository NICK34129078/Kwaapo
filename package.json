{
  "name": "lumen-fashion",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --lan",
    "start:tunnel": "expo start --tunnel",
    "start:phone": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-expo-phone.ps1",
    "start:staging": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-expo-staging.ps1",
    "start:lan": "expo start --lan",
    "start:localhost": "expo start --localhost",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web --localhost --port 8082",
    "start:cursor": "expo start --web --localhost --port 8082",
    "supabase:login": "npx supabase@latest login",
    "supabase:link": "npx supabase@latest link",
    "supabase:push": "npx supabase@latest db push",
    "supabase:diff": "npx supabase@latest db diff",
    "deploy:worker": "wrangler deploy",
    "validate:release": "node scripts/validate-release-config.mjs check",
    "validate:release:production": "node scripts/validate-release-config.mjs production",
    "test:release-config": "npx tsx src/config/releaseConfig.test.ts",
    "test:buyer-orders": "npx tsx src/utils/buyerOrders.test.ts",
    "test:in-app-notifications": "npx tsx src/utils/inAppNotification.test.ts",
    "test:feed-telemetry": "npx tsx src/utils/feedTelemetry.test.ts",
    "test:ranked-feed-ladder": "npx tsx src/utils/rankedFeedLadder.test.ts",
    "test:global-feed-refresh": "npx tsx src/utils/globalFeedRefresh.test.ts",
    "test:feed": "npm run test:feed-telemetry && npm run test:ranked-feed-ladder && npm run test:global-feed-refresh && npx tsx src/utils/feedRanking.helpers.test.ts && npx tsx src/utils/feedMuteFilter.test.ts && npx tsx src/utils/globalFeedLoadMore.test.ts && npx tsx src/services/commentLearning.test.ts && npx tsx src/utils/feedCreatorSpacing.test.ts && npx tsx src/utils/feedInterests.test.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.14.13",
    "@supabase/supabase-js": "2.45.4",
    "buffer": "^6.0.3",
    "expo": "~54.0.35",
    "expo-asset": "~12.0.12",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-localization": "^57.0.0",
    "expo-notifications": "~0.32.17",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-video-thumbnails": "~10.0.8",
    "expo-web-browser": "~15.0.11",
    "i18next": "^26.3.4",
    "jpeg-js": "^0.4.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jpeg-js": "^0.3.0",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.0",
    "typescript": "~5.9.2",
    "wrangler": "^4.83.0"
  },
  "private": true
}
